# ══════════════════════════════════════════
# Crompressor-Neurônio — .gitignore
# ══════════════════════════════════════════

# ── Binários Go ──
pesquisas/testes/bin/
*.exe
*.out
*.test
*.prof

# ── Python (Tensor-Vivo + Visualização) ──
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ── Modelos e Dados Pesados (regeneráveis) ──
pesquisas/modelos/*.gguf
pesquisas/modelos/*.crom
pesquisas/tensor-vivo/dados/mnist/
pesquisas/tensor-vivo/dados/cifar10/
pesquisas/tensor-vivo/dados/*.pt
pesquisas/tensor-vivo/dados/_tmp_*
pesquisas/dados/*.json
!pesquisas/dados/.gitkeep
!pesquisas/dados/relatorios/*

# ── Resultados Experimentais (manter JSONs de resultado) ──
# Os .json de resultados SÃO versionados (dados científicos)
# Mas plots regeneráveis não
pesquisas/tensor-vivo/dados/*.png
pesquisas/relatorios/graficos/
pesquisas/relatorios/dashboard/
pesquisas/relatorios/*.md
!pesquisas/relatorios/.gitkeep

# ── Binários e Logs de Debug Go ──
pesquisas/testes/fuse_demon_check
pesquisas/testes/fuse_test_bin
pesquisas/testes/test_multi_brain
pesquisas/testes/test_p2p_delta
pesquisas/testes/run_all
pesquisas/testes/*.log
pesquisas/testes/inference.tmp

# ── Pontos de Montagem VFS ──
pesquisas/fuse_mnt/
pesquisas/modelos/fuse_mnt/

# ── Node (Web Cockpit) ──
web-cockpit/node_modules/
web-cockpit/dist/
web-cockpit/.env

# ── OS/IDE ──
.DS_Store
Thumbs.db
*~
.vscode/
.idea/
*.swp
*.swo
.gemini/
